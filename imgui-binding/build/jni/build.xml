<project name="imgui-java-natives" basedir="." default="all">
	<target name="clean">
		<ant antfile="build-linux64.xml" target="clean"/>

	</target>
	
	<target name="compile-natives">
		<ant antfile="build-linux64.xml"/>

	</target>
	
	<target name="pack-natives">
		<jar destfile="../libsNative/imgui-java-natives.jar">
			<fileset dir="../libsNative/linux64" includes="libimgui-java64.so"/>

		</jar>
	</target>

	<target name="all" depends="compile-natives,pack-natives"/>
</project>
